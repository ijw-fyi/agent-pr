{
    "name": "pr-review-agent",
    "version": "1.10.1",
    "description": "AI-powered PR review agent using LangChain and OpenRouter",
    "type": "module",
    "main": "action/index.js",
    "scripts": {
        "build": "rm -rf action && tsc && ncc build dist/index.js -o action && mkdir -p action/wasm && cp src/helpers/wasm/* action/wasm/",
        "dev": "tsx src/index.ts",
        "typecheck": "tsc --noEmit",
        "release": "yarn build && git add action/ && yarn version && git push && git push --tags"
    },
    "dependencies": {
        "@actions/core": "^1.10.1",
        "@actions/github": "^6.0.0",
        "@google/genai": "^1.37.0",
        "@langchain/core": "^0.3.58",
        "@langchain/langgraph": "^0.2.0",
        "@langchain/openai": "^0.3.0",
        "@modelcontextprotocol/sdk": "^1.0.0",
        "@types/glob": "^8.1.0",
        "glob": "^13.0.0",
        "safe-regex2": "^5.0.0",
        "simple-git": "^3.30.0",
        "web-tree-sitter": "^0.26.3",
        "zod": "^3.23.0"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@vercel/ncc": "^0.38.0",
        "tree-sitter-c": "^0.24.1",
        "tree-sitter-cli": "^0.26.3",
        "tree-sitter-cpp": "^0.23.4",
        "tree-sitter-javascript": "^0.25.0",
        "tree-sitter-python": "^0.25.0",
        "tree-sitter-typescript": "^0.23.2",
        "tsx": "^4.0.0",
        "typescript": "^5.0.0"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}